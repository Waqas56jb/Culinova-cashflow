# ===== CULINOVA Server Environment =====
# Copy this file to ".env" and fill in your real values.

PORT=5000
NODE_ENV=development

# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Use the SERVICE ROLE key here (server-side only, never expose to frontend)
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- CORS (comma separated allowed origins, NO trailing slash) ---
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,https://culinova-cashflow-admin.vercel.app,https://culinova-cashflow-client.vercel.app

# --- First admin (created by `npm run seed` style insert in schema.sql) ---
# Default admin login is created in db/schema.sql -> see README
